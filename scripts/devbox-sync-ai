#!/usr/bin/env bash
# Remote shell snippets intentionally use single quotes; rsync destinations use
# remote-home paths like ~/.pi.
# shellcheck disable=SC2016,SC2088
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: scripts/devbox-sync-ai [options] [workspace-label|devbox-name|ssh-host]

Sync personal AI/editor config into a PostHog Coder devbox. Personal only:
no Coder template or shared workspace settings are changed.

Default sync:
  - ~/.pi/agent/settings.json, AGENTS.md, skills, prompts, themes, extensions,
    agents, compound-engineering
  - ~/.codex/AGENTS.md and ~/.codex/skills
  - ~/.claude/CLAUDE.md and ~/.claude/skills
  - ~/.agents/skills
  - persops/modules/nvim -> ~/.config/nvim, plus devbox Neovim warmup

Skipped by default:
  - ~/.pi/agent/auth.json
  - agent auth, sessions, history, caches, logs, and machine-local state

Options:
  --start              Run `hogli devbox:start` before syncing
  --dry-run            Print actions without changing the remote
  --with-auth          Also copy ~/.pi/agent/auth.json (opt-in secret copy)
  --delete             Mirror synced directories with rsync --delete
  --no-pi              Do not sync Pi config
  --no-codex           Do not sync Codex instructions/skills
  --no-claude          Do not sync Claude instructions/skills
  --no-agents          Do not sync ~/.agents/skills
  --no-nvim            Do not sync Neovim config
  --no-install-pi      Do not try to install Pi if missing on the devbox
  --no-pi-update       Do not run `pi update` after syncing settings
  --no-verify          Do not run remote post-sync checks
  -h, --help           Show this help

Examples:
  scripts/devbox-sync-ai --start
  scripts/devbox-sync-ai api
  scripts/devbox-sync-ai devbox-catalini --with-auth
  scripts/devbox-sync-ai coder.devbox-catalini
USAGE
}

repo_root() {
  cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd
}

quote_cmd() {
  printf '+ '
  printf '%q ' "$@"
  printf '\n'
}

run() {
  if [[ "$dry_run" == "1" ]]; then
    quote_cmd "$@"
  else
    "$@"
  fi
}

coder_bin() {
  if [[ -x "$HOME/.hogli/bin/coder" ]]; then
    printf '%s\n' "$HOME/.hogli/bin/coder"
    return
  fi
  command -v coder || {
    echo "error: coder CLI not found. Run: hogli devbox:setup" >&2
    exit 1
  }
}

coder_username() {
  "$CODER_BIN" whoami --output json | python3 -c '
import json, sys
payload = json.load(sys.stdin)
if isinstance(payload, list):
    payload = payload[0] if payload else {}
username = payload.get("username") or payload.get("name")
if not username:
    raise SystemExit("could not determine Coder username")
print(username.lower())
'
}

resolve_workspace() {
  local target="$1"

  if [[ -z "$target" ]]; then
    local username
    CODER_BIN="$(coder_bin)"
    username="$(coder_username)"
    printf 'devbox-%s\n' "$username"
  elif [[ "$target" == coder.* ]]; then
    printf '%s\n' "${target#coder.}"
  elif [[ "$target" == devbox-* ]]; then
    printf '%s\n' "$target"
  elif [[ "$target" == @* ]]; then
    echo "error: @user workspace syntax is not supported by this personal sync script" >&2
    exit 1
  else
    local username
    CODER_BIN="$(coder_bin)"
    username="$(coder_username)"
    printf 'devbox-%s-%s\n' "$username" "$target"
  fi
}

remote_sh() {
  local script="$1"
  if [[ "$dry_run" == "1" ]]; then
    echo "+ ssh $ssh_host bash -s <<'REMOTE'"
    printf '%s\n' "$script"
    echo "REMOTE"
  else
    ssh "$ssh_host" bash -s <<<"$script"
  fi
}

rsync_file() {
  local label="$1"
  local src="$2"
  local dst="$3"

  if [[ ! -f "$src" ]]; then
    echo "skip: $label ($src missing)" >&2
    return
  fi

  echo "sync: $label"
  run rsync -azL "$src" "$ssh_host:$dst"
  remote_sh "chmod 600 $dst"
}

rsync_dir() {
  local label="$1"
  local src="$2"
  local dst="$3"
  local args=(-azL)

  if [[ ! -d "$src" ]]; then
    echo "skip: $label ($src missing)" >&2
    return
  fi
  if [[ "$mirror_dirs" == "1" ]]; then
    args+=(--delete)
  fi

  echo "sync: $label"
  run rsync "${args[@]}" "$src/" "$ssh_host:$dst/"
  remote_sh "chmod -R u+rwX,go+rX,go-w $dst"
}

sync_file_if_present() {
  local label="$1"
  local src="$2"
  local dst="$3"

  if [[ -e "$src" ]]; then
    rsync_file "$label" "$src" "$dst"
  else
    echo "skip: $label ($src missing)" >&2
  fi
}

start_workspace() {
  echo "start: $workspace"
  if command -v hogli >/dev/null 2>&1 && [[ "$workspace_target" != devbox-* && "$workspace_target" != coder.* ]]; then
    if [[ -n "$workspace_target" && "$workspace_target" != devbox-* ]]; then
      run hogli devbox:start "$workspace_target"
    else
      run hogli devbox:start
    fi
  else
    local coder
    coder="$(coder_bin)"
    run "$coder" start "$workspace" --yes
  fi
}

prepare_remote_pi() {
  remote_sh "$(cat <<'REMOTE'
set -e

mkdir -p "$HOME/.pi/agent" "$HOME/.local/bin" "$HOME/.local/npm/bin"

path_line='export PATH="$HOME/.local/bin:$HOME/.local/npm/bin:$PATH"'
for profile in "$HOME/.profile" "$HOME/.bashrc" "$HOME/.zshrc"; do
  touch "$profile"
  grep -qxF "$path_line" "$profile" || printf '\n%s\n' "$path_line" >> "$profile"
done

install_pi_with_npm() {
  npm config set prefix "$HOME/.local/npm" >/dev/null
  npm install -g @earendil-works/pi-coding-agent
}

if [ ! -x "$HOME/.local/npm/bin/pi" ]; then
  if command -v npm >/dev/null 2>&1; then
    install_pi_with_npm
  elif command -v flox >/dev/null 2>&1 && [ -d "$HOME/posthog/.flox" ]; then
    flox activate -d "$HOME/posthog" -- bash -lc 'npm config set prefix "$HOME/.local/npm" >/dev/null && npm install -g @earendil-works/pi-coding-agent'
  else
    echo "warning: pi missing and neither npm nor PostHog flox npm is available" >&2
  fi
fi

cat > "$HOME/.local/bin/pi" <<'PI_WRAPPER'
#!/bin/sh
set -eu

pi_bin="${PI_NPM_BIN:-$HOME/.local/npm/bin/pi}"
if [ ! -x "$pi_bin" ]; then
  echo "pi is not installed at $pi_bin; rerun scripts/devbox-sync-ai" >&2
  exit 127
fi

if command -v node >/dev/null 2>&1; then
  exec "$pi_bin" "$@"
fi

pi_target="$pi_bin"
if command -v readlink >/dev/null 2>&1 && [ -L "$pi_bin" ]; then
  pi_target="$(readlink -f "$pi_bin" 2>/dev/null || printf '%s\n' "$pi_bin")"
fi

node_bin=""
if [ -d "$HOME/posthog/.flox/run" ]; then
  node_bin="$(find -L "$HOME/posthog/.flox/run" -path '*/bin/node' -type f -perm -111 -print -quit 2>/dev/null || true)"
fi

if [ -n "$node_bin" ] && [ -r "$pi_target" ]; then
  PATH="${node_bin%/*}:$PATH"
  export PATH
  exec "$node_bin" "$pi_target" "$@"
fi

if command -v flox >/dev/null 2>&1 && [ -d "$HOME/posthog/.flox" ]; then
  exec flox activate -d "$HOME/posthog" -- "$pi_bin" "$@"
fi

echo "pi requires node; neither node nor PostHog flox node is available" >&2
exit 127
PI_WRAPPER
chmod 755 "$HOME/.local/bin/pi"
REMOTE
)"
}

sync_pi() {
  local pi_dir="$HOME/.pi/agent"

  remote_sh 'set -e
mkdir -p ~/.pi/agent/skills ~/.pi/agent/prompts ~/.pi/agent/themes ~/.pi/agent/extensions ~/.pi/agent/agents ~/.pi/agent/compound-engineering
'

  rsync_file "Pi settings" "$pi_dir/settings.json" "~/.pi/agent/settings.json"
  rsync_file "Pi AGENTS" "$pi_dir/AGENTS.md" "~/.pi/agent/AGENTS.md"
  rsync_dir "Pi skills" "$pi_dir/skills" "~/.pi/agent/skills"
  rsync_dir "Pi prompts" "$pi_dir/prompts" "~/.pi/agent/prompts"
  rsync_dir "Pi themes" "$pi_dir/themes" "~/.pi/agent/themes"
  rsync_dir "Pi extensions" "$pi_dir/extensions" "~/.pi/agent/extensions"
  rsync_dir "Pi agents" "$pi_dir/agents" "~/.pi/agent/agents"
  rsync_dir "Pi compound-engineering" "$pi_dir/compound-engineering" "~/.pi/agent/compound-engineering"

  if [[ "$copy_auth" == "1" ]]; then
    rsync_file "Pi auth (secret)" "$pi_dir/auth.json" "~/.pi/agent/auth.json"
  else
    echo "skip: Pi auth.json (pass --with-auth to copy secret auth)"
  fi
}

sync_codex() {
  remote_sh 'set -e
mkdir -p ~/.codex/skills
'
  sync_file_if_present "Codex AGENTS" "$HOME/.codex/AGENTS.md" "~/.codex/AGENTS.md"
  rsync_dir "Codex skills" "$HOME/.codex/skills" "~/.codex/skills"
}

sync_claude() {
  remote_sh 'set -e
mkdir -p ~/.claude/skills
'
  sync_file_if_present "Claude instructions" "$HOME/.claude/CLAUDE.md" "~/.claude/CLAUDE.md"
  rsync_dir "Claude skills" "$HOME/.claude/skills" "~/.claude/skills"
}

sync_agents() {
  remote_sh 'set -e
mkdir -p ~/.agents/skills
'
  rsync_dir "global Agent Skills" "$HOME/.agents/skills" "~/.agents/skills"
}

sync_nvim() {
  local root
  root="$(repo_root)"
  remote_sh 'set -e
mkdir -p ~/.config/nvim
'
  rsync_dir "Neovim config" "$root/modules/nvim" "~/.config/nvim"
}

prepare_remote_nvim() {
  remote_sh "$(cat <<'REMOTE'
set -e

mkdir -p "$HOME/.local/bin" "$HOME/.local/npm/bin" "$HOME/.config/fish/conf.d"

path_line='export PATH="$HOME/.local/bin:$HOME/.local/npm/bin:$PATH"'
vi_alias="alias vi='nvim'"
vim_alias="alias vim='nvim'"
for profile in "$HOME/.profile" "$HOME/.bashrc" "$HOME/.zshrc"; do
  touch "$profile"
  grep -qxF "$path_line" "$profile" || printf '\n%s\n' "$path_line" >> "$profile"
  grep -qxF "$vi_alias" "$profile" || printf '%s\n' "$vi_alias" >> "$profile"
  grep -qxF "$vim_alias" "$profile" || printf '%s\n' "$vim_alias" >> "$profile"
done

cat > "$HOME/.config/fish/conf.d/nvim-aliases.fish" <<'FISH'
fish_add_path -g "$HOME/.local/bin" "$HOME/.local/npm/bin"
alias vi='nvim'
alias vim='nvim'
FISH

export PATH="$HOME/.local/bin:$HOME/.local/npm/bin:/snap/bin:$PATH"

nvim_ok() {
  command -v nvim >/dev/null 2>&1 &&
    nvim --clean --headless "+lua assert(vim.fn.has('nvim-0.11.2') == 1, 'Neovim 0.11.2+ required')" +qa >/dev/null 2>&1
}

install_snap_nvim() {
  command -v snap >/dev/null 2>&1 || return 1
  command -v sudo >/dev/null 2>&1 || return 1
  sudo -n true >/dev/null 2>&1 || return 1
  sudo -n snap install nvim --classic
}

python_venv_ok() {
  command -v python3 >/dev/null 2>&1 || return 1
  local tmp
  tmp="$(mktemp -d)"
  python3 -m venv "$tmp/venv" >/dev/null 2>&1
  local status=$?
  rm -rf "$tmp"
  return "$status"
}

install_apt_nvim_deps() {
  local needs=()
  command -v unzip >/dev/null 2>&1 || needs+=(unzip)
  python_venv_ok || needs+=(python3-venv)
  [[ "${#needs[@]}" -gt 0 ]] || return 0

  command -v apt-get >/dev/null 2>&1 || return 1
  command -v sudo >/dev/null 2>&1 || return 1
  sudo -n true >/dev/null 2>&1 || return 1
  sudo -n apt-get update || echo "warning: apt-get update failed; trying install with existing indexes" >&2
  sudo -n apt-get install -y "${needs[@]}"
}

if ! nvim_ok; then
  install_snap_nvim || {
    echo "error: nvim missing or too old; install with: sudo snap install nvim --classic" >&2
    exit 1
  }
fi

if [ -x /snap/bin/nvim ]; then
  cat > "$HOME/.local/bin/nvim" <<'SH'
#!/bin/sh
exec /snap/bin/nvim "$@"
SH
  chmod 755 "$HOME/.local/bin/nvim"
fi

for cmd in vi vim; do
  cat > "$HOME/.local/bin/$cmd" <<'SH'
#!/bin/sh
exec nvim "$@"
SH
  chmod 755 "$HOME/.local/bin/$cmd"
done

install_apt_nvim_deps || {
  echo "error: missing Mason runtime deps; install with: sudo apt-get install -y unzip python3-venv" >&2
  exit 1
}

printf 'nvim: '
command -v nvim
nvim --version | sed -n '1p'
REMOTE
)"
}

configure_remote_nvim() {
  remote_sh 'set -e
mkdir -p ~/.config/nvim/lua/plugins
cat > ~/.config/nvim/lua/plugins/devbox.lua <<'"'"'LUA'"'"'
return {
  {
    "supermaven-inc/supermaven-nvim",
    enabled = false,
  },
}
LUA
'
}

warm_remote_nvim() {
  remote_sh "$(cat <<'REMOTE'
set -e

warm_tmp="$(mktemp -d)"
trap 'rm -rf "$warm_tmp"' EXIT
warm_script="$warm_tmp/warm.sh"

cat > "$warm_script" <<'SH'
set -e
export PATH="$HOME/.local/bin:$HOME/.local/npm/bin:$PATH"
warm_tmp="$(cd "$(dirname "$0")" && pwd)"

die() {
  printf '%s\n' "$1" >&2
  exit 1
}

printf "warm: Lazy restore\n"
nvim --headless "+Lazy! restore" +qa

printf "warm: Mason packages\n"
mason_lua="$warm_tmp/mason.lua"
cat > "$mason_lua" <<'LUA'
local plugin = require("lazy.core.config").plugins["mason.nvim"] or {}
local opts = vim.deepcopy(plugin.opts or {})
local packages = opts.ensure_installed or {}
opts.ensure_installed = nil

local function die(message)
  vim.api.nvim_err_writeln(message)
  vim.cmd("cquit 1")
end

if not plugin.dir then
  die("mason.nvim plugin dir unavailable")
end
vim.opt.rtp:prepend(plugin.dir)

local ok_mason, mason = pcall(require, "mason")
if not ok_mason then
  die("mason unavailable")
end
mason.setup(opts)

local ok_registry, registry = pcall(require, "mason-registry")
if not ok_registry then
  die("mason registry unavailable")
end

local refreshed = false
registry.refresh(function()
  refreshed = true
end)

if not vim.wait(60000, function()
  return refreshed
end, 100) then
  die("timed out refreshing mason registry")
end

local state = { missing = {}, installing = {}, unknown = {}, done = false }

local function join(values)
  table.sort(values)
  return table.concat(values, ", ")
end

local function snapshot()
  state = { missing = {}, installing = {}, unknown = {}, done = false }
  for _, name in ipairs(packages) do
    local ok_package, package = pcall(registry.get_package, name)
    if not ok_package then
      table.insert(state.unknown, name)
    elseif package:is_installing() then
      table.insert(state.installing, name)
    elseif not package:is_installed() then
      table.insert(state.missing, name)
    end
  end
  state.done = #state.missing == 0 and #state.installing == 0 and #state.unknown == 0
  return state
end

local seen = {}
for _, name in ipairs(packages) do
  if not seen[name] then
    seen[name] = true
    local ok_package, package = pcall(registry.get_package, name)
    if not ok_package then
      die("unknown Mason package: " .. name)
    end
    if not package:is_installed() and not package:is_installing() then
      local ok_install, install_err = pcall(function()
        package:install()
      end)
      if not ok_install then
        die("failed to start Mason package install for " .. name .. ": " .. tostring(install_err))
      end
    end
  end
end

local completed = vim.wait(600000, function()
  return snapshot().done
end, 1000)

local final = snapshot()
if not completed then
  die("timed out waiting for Mason packages; installing: " .. join(final.installing) .. "; missing: " .. join(final.missing))
end
if not final.done then
  die("Mason packages not installed; missing: " .. join(final.missing) .. "; installing: " .. join(final.installing) .. "; unknown: " .. join(final.unknown))
end

vim.cmd("qa")
LUA
nvim --headless "+luafile $mason_lua" || die "Mason warmup failed"

printf "warm: treesitter parsers\n"
treesitter_lua="$warm_tmp/treesitter.lua"
cat > "$treesitter_lua" <<'LUA'
local function die(message)
  vim.api.nvim_err_writeln(message)
  vim.cmd("cquit 1")
end

require("lazy").load({ plugins = { "nvim-treesitter" } })

local config_path = vim.fn.stdpath("config") .. "/lua/plugins/treesitter.lua"
local ok_spec, spec = pcall(dofile, config_path)
if not ok_spec then
  die("failed to read treesitter spec: " .. tostring(spec))
end

local languages = spec.opts and spec.opts.ensure_installed or {}
local ok_install, install = pcall(require, "nvim-treesitter.install")
if not ok_install then
  die("nvim-treesitter installer unavailable")
end

local task = install.install(languages, { summary = true, max_jobs = 8 })
local ok_wait, installed = pcall(function()
  return task:wait(600000)
end)
if not ok_wait then
  die("treesitter warmup failed: " .. tostring(installed))
end
if not installed then
  die("one or more treesitter parsers failed to install")
end

vim.cmd("qa")
LUA
nvim --headless "+luafile $treesitter_lua" || die "treesitter warmup failed"
SH

if command -v flox >/dev/null 2>&1 && [ -d "$HOME/posthog/.flox" ]; then
  flox activate -d "$HOME/posthog" -- bash "$warm_script"
else
  bash "$warm_script"
fi
REMOTE
)"
}

update_remote_pi_packages() {
  remote_sh 'set -e
export PATH="$HOME/.local/bin:$HOME/.local/npm/bin:$PATH"
if command -v pi >/dev/null 2>&1; then
  # Several Pi extensions still declare peers on the pre-rename package.
  NPM_CONFIG_LEGACY_PEER_DEPS=true pi update || echo "warning: pi update failed; config was still synced" >&2
else
  echo "warning: pi not found; skipping pi update" >&2
fi
'
}

verify_remote() {
  local verify_nvim="${1:-1}"
  local script

  script="$(cat <<'REMOTE'
set -e
export PATH="$HOME/.local/bin:$HOME/.local/npm/bin:$PATH"

test -f "$HOME/.pi/agent/settings.json"
test -f "$HOME/.pi/agent/AGENTS.md"
test -d "$HOME/.pi/agent/skills"
test -d "$HOME/.pi/agent/extensions"
test -d "$HOME/.pi/agent/agents"
test -d "$HOME/.codex/skills"
test -d "$HOME/.claude/skills"
test -d "$HOME/.agents/skills"
if [ "$VERIFY_NVIM" = "1" ]; then
  test -f "$HOME/.config/nvim/init.lua"
  test -f "$HOME/.config/nvim/lua/plugins/devbox.lua"
fi

printf "verify: plain pi -> "
command -v pi
pi --version

if [ "$VERIFY_NVIM" = "1" ]; then
  printf "verify: nvim -> "
  command -v nvim
  nvim --version | sed -n "1p"
  printf "verify: vi -> "
  command -v vi
  printf "verify: vim -> "
  command -v vim
fi

if command -v flox >/dev/null 2>&1 && [ -d "$HOME/posthog/.flox" ]; then
  flox activate -d "$HOME/posthog" -- bash -lc '"'"'export PATH="$HOME/.local/bin:$HOME/.local/npm/bin:$PATH"; printf "verify: flox pi -> "; command -v pi; pi --version'"'"'
fi
REMOTE
)"
  remote_sh "VERIFY_NVIM=$verify_nvim
$script"
}

workspace_target=""
dry_run=0
copy_auth=0
mirror_dirs=0
do_pi=1
do_codex=1
do_claude=1
do_agents=1
do_nvim=1
install_pi=1
pi_update=1
do_start=0
do_verify=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --start) do_start=1 ;;
    --dry-run) dry_run=1 ;;
    --with-auth) copy_auth=1 ;;
    --delete) mirror_dirs=1 ;;
    --no-pi) do_pi=0 ;;
    --no-codex) do_codex=0 ;;
    --no-claude) do_claude=0 ;;
    --no-agents) do_agents=0 ;;
    --no-nvim) do_nvim=0 ;;
    --no-install-pi) install_pi=0 ;;
    --no-pi-update) pi_update=0 ;;
    --no-verify) do_verify=0 ;;
    -h|--help)
      usage
      exit 0
      ;;
    --*)
      echo "error: unknown option $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$workspace_target" ]]; then
        echo "error: only one workspace argument is supported" >&2
        exit 1
      fi
      workspace_target="$1"
      ;;
  esac
  shift
done

workspace="$(resolve_workspace "$workspace_target")"
ssh_host="coder.$workspace"

echo "workspace: $workspace"
echo "ssh host:  $ssh_host"

if [[ "$do_start" == "1" ]]; then
  start_workspace
fi

if [[ "$install_pi" == "1" && "$do_pi" == "1" ]]; then
  prepare_remote_pi
fi

if [[ "$do_pi" == "1" ]]; then
  sync_pi
fi
if [[ "$do_codex" == "1" ]]; then
  sync_codex
fi
if [[ "$do_claude" == "1" ]]; then
  sync_claude
fi
if [[ "$do_agents" == "1" ]]; then
  sync_agents
fi
if [[ "$do_nvim" == "1" ]]; then
  prepare_remote_nvim
  sync_nvim
  configure_remote_nvim
  warm_remote_nvim
fi
if [[ "$pi_update" == "1" && "$do_pi" == "1" ]]; then
  update_remote_pi_packages
fi
if [[ "$do_verify" == "1" && "$dry_run" != "1" ]]; then
  verify_remote "$do_nvim"
fi

echo "done"
if [[ "$copy_auth" != "1" ]]; then
  echo "note: Pi auth was not copied. Open remote \`pi\`, run /login, or rerun with --with-auth if you accept copying auth.json."
fi
